# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Postgres (also backs the TimescaleDB score_history hypertable)
DATABASE_URL=postgres://astraguard:astraguard@localhost:5432/astraguard

# Redis (cache + BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Stellar
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Oracle account used for privileged contract calls (set_coverage, anchor_flag, ...).
# NEVER put a real secret key here outside local dev — production holds this in a KMS/HSM.
ORACLE_PUBLIC_KEY=
ORACLE_SECRET_KEY=

# API auth
API_KEY_SALT=dev-only-change-me

# Third-party KYC provider (verification/kyc) — left blank until a provider is selected
KYC_PROVIDER_API_KEY=

# astraguard-contracts deployment IDs (see that repo's deployments/<network>.json).
# Oracle calls no-op with a warning until these are set.
REGISTRY_ANCHOR_CONTRACT_ID=
INSURANCE_POOL_CONTRACT_ID=

# Webhook the safetynet/exchange-alerts module posts to for exchange compliance notices.
EXCHANGE_ALERT_WEBHOOK_URL=

# Comma-separated allowed origins for the dashboard/extension in production (e.g.
# https://app.astraguard.io,https://astraguard.io). Ignored outside production — dev reflects
# any origin.
CORS_ORIGINS=
